# Database (Supabase connection strings - you need BOTH)
# DATABASE_URL: "Transaction pooler" - what your running app uses day-to-day
# IMPORTANT: must end in ?pgbouncer=true&connection_limit=1 or you'll hit
# "prepared statement already exists" errors - transaction-mode poolers
# don't support prepared statements the way Prisma expects by default.
DATABASE_URL="postgresql://...?pgbouncer=true&connection_limit=1"
# DIRECT_URL: Session pooler (port 5432) - needed for `prisma db push` only.
# Replit can't reach Supabase's true direct connection (IPv6-only), so we
# use the session pooler here instead - same host as above, different port.
DIRECT_URL="postgresql://..."

# Clerk (from clerk.com dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."
# Not setting sign-in/sign-up URLs on purpose - Clerk falls back to its own
# hosted Account Portal (the *.accounts.dev URL), which works fine and
# means we don't need to build custom sign-in pages right now.

# Your app's live URL (used in unsubscribe links in mass emails)
NEXT_PUBLIC_APP_URL="https://yourapp.replit.dev"

# Comma-separated list of hostnames that ARE the ops/CRM app itself.
# Anything NOT in this list is treated as a client's public website and
# skips Clerk auth entirely. Include your Replit dev URL, your Replit
# deployment URL, and any real ops domain you set up later.
OPS_APP_HOSTS="yourapp.replit.dev,yourapp.replit.app"

# Resend (mass email)
RESEND_API_KEY="re_..."
RESEND_WEBHOOK_SECRET="whsec_..."

# Vercel (for site generator deploys - Day 1 task)
VERCEL_API_TOKEN=""
