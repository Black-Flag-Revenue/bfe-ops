# Database (Supabase connection strings - you need BOTH)
# DATABASE_URL: "Transaction pooler" - what your running app uses day-to-day
DATABASE_URL="postgresql://..."
# DIRECT_URL: "Direct connection" (or Session pooler) - needed for `prisma db push`
# and migrations only. Transaction pooler mode doesn't support what Prisma
# needs to actually change the schema.
DIRECT_URL="postgresql://..."

# Clerk (from clerk.com dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
CLERK_SECRET_KEY="sk_..."
# Not setting sign-in/sign-up URLs on purpose - Clerk falls back to its own
# hosted Account Portal (the *.accounts.dev URL), which works fine and
# means we don't need to build custom sign-in pages right now.

# Your app's live URL (used in unsubscribe links in mass emails)
NEXT_PUBLIC_APP_URL="https://yourapp.replit.dev"

# Resend (mass email)
RESEND_API_KEY="re_..."
RESEND_WEBHOOK_SECRET="whsec_..."

# Vercel (for site generator deploys - Day 1 task)
VERCEL_API_TOKEN=""
